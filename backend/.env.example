# =============================================================================
# SmartAtSys Backend — Environment Configuration
# Copy this file to .env and fill in values. Never commit .env to git.
# Full guide: docs/ENV.md
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER — safe defaults (change CORS_ORIGIN when frontend URL is known)
# -----------------------------------------------------------------------------
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# REQUIRED — server will NOT start without these
# -----------------------------------------------------------------------------
# JWT_SECRET → YOU: invent a random string (min 8 characters). Example:
# JWT_SECRET=my-dev-secret-key-2026
JWT_SECRET=change-me-to-your-own-secret-min-8-chars
JWT_EXPIRES_IN=8h

# FABRIC_WAREHOUSE_* → DB / Fabric team (SQL auth connection to warehouse)
FABRIC_WAREHOUSE_SERVER=your-server.datawarehouse.fabric.microsoft.com
FABRIC_WAREHOUSE_DATABASE=SmartAttendanceWarehouse
FABRIC_WAREHOUSE_USER=backend_service_user
FABRIC_WAREHOUSE_PASSWORD=change-me

# Usually keep these for Fabric Warehouse (do not change unless DB team says so)
FABRIC_WAREHOUSE_ENCRYPT=true
FABRIC_WAREHOUSE_TRUST_SERVER_CERT=false

# -----------------------------------------------------------------------------
# OPTIONAL — metadata only (not used by backend code; for your notes)
# -----------------------------------------------------------------------------
# FABRIC_WORKSPACE_ID → Fabric team (optional; same GUID as Power BI workspace often)
# FABRIC_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# YOU SET — admin faculty IDs from your database seed data
# -----------------------------------------------------------------------------
ADMIN_FACULTY_IDS=1

# -----------------------------------------------------------------------------
# OPTIONAL — Power BI (Azure embed SKIPPED for now)
# Set POWERBI_DASHBOARD_URL to your Fabric report link for "open in browser" mode.
# Azure vars (CLIENT_ID, CLIENT_SECRET, TENANT_ID) not needed until in-app embed.
# -----------------------------------------------------------------------------

# Your Fabric report URL (opens in browser — no Azure required)
POWERBI_DASHBOARD_URL=https://app.fabric.microsoft.com/groups/{workspaceId}/reports/{reportId}?experience=power-bi
POWERBI_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
POWERBI_REPORT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Only needed later for in-app embed (Azure AD — skip for now)
# POWERBI_EMBED_URL=https://app.powerbi.com/reportEmbed
# POWERBI_CLIENT_ID=
# POWERBI_CLIENT_SECRET=
# POWERBI_TENANT_ID=

# -----------------------------------------------------------------------------
# OPTIONAL — tuning (defaults are fine for development)
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOG_LEVEL=info
